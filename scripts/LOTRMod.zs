// Add recipes for conversions between LOTR resources
// Vanilla
recipes.addShapeless(<minecraft:diamond>, [<lotr:item.diamond>]);
recipes.addShapeless(<lotr:item.diamond>, [<ore:gemDiamond>]);
recipes.addShapeless(<minecraft:emerald>, [<lotr:item.emerald>]);
recipes.addShapeless(<lotr:item.emerald>, [<ore:gemEmerald>]);

// Thaumcraft
recipes.addShapeless(<Thaumcraft:ItemResource:6>, [<lotr:item.amber>]);
recipes.addShapeless(<lotr:item.amber>, [<ore:gemAmber>]);